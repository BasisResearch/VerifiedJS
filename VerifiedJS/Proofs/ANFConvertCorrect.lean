        · simp at hstep
    | assign name rhs =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · simp at hstep
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep
            obtain ⟨_, rfl⟩ := hstep
            exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.assign_val h)) (by assumption)
          · simp at hstep
        · simp at hstep
    | «if» cond then_ else_ =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · simp at hstep
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep
            obtain ⟨_, rfl⟩ := hstep
            exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.if_cond h)) (by assumption)
          · simp at hstep
        · simp at hstep
    | unary op arg =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · simp at hstep
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep
            obtain ⟨_, rfl⟩ := hstep
            exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.unary_arg h)) (by assumption)
          · simp at hstep
        · simp at hstep
    | typeof arg =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · simp at hstep
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep
            obtain ⟨_, rfl⟩ := hstep
            exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.typeof_arg h)) (by assumption)
          · simp at hstep
        · simp at hstep
    | throw arg =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · simp [Flat.pushTrace] at hstep; obtain ⟨_, rfl⟩ := hstep; exact ⟨_, rfl⟩
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep
            obtain ⟨_, rfl⟩ := hstep
            exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.throw_arg h)) (by assumption)
          · simp at hstep
        · simp at hstep
    | await arg =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · simp at hstep
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep
            obtain ⟨_, rfl⟩ := hstep
            exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.await_arg h)) (by assumption)
          · simp at hstep
        · simp at hstep
    | binary op lhs rhs =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep
            obtain ⟨_, rfl⟩ := hstep
            exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.binary_lhs h)) (by assumption)
          · simp at hstep
        · simp at hstep
      · split at hstep
        · split at hstep
          · split at hstep
            · simp [Flat.pushTrace] at hstep
              obtain ⟨_, rfl⟩ := hstep
              exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.binary_rhs h)) (by assumption)
            · simp at hstep
          · simp at hstep
