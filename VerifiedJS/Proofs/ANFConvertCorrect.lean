    | getProp obj prop =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · simp at hstep
      · simp at hstep
      · simp at hstep
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep
            obtain ⟨_, rfl⟩ := hstep
            exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.getProp_obj h)) (by assumption)
