      · exact hno (HasReturnInHead.deleteProp_obj hleft)
      · exact absurd hkt (ANF.bindComplex_never_return_none_general _ _ _ _)
    | typeof val =>
      exfalso; simp only [ANF.normalizeExpr] at h
      rcases ANF.normalizeExpr_return_none_or_k val _ _ _ h with hleft | ⟨_, _, _, hkt⟩
      · exact hno (HasReturnInHead.typeof_arg hleft)
      · exact absurd hkt (ANF.bindComplex_never_return_none_general _ _ _ _)
    | unary _ val =>
      exfalso; simp only [ANF.normalizeExpr] at h
      rcases ANF.normalizeExpr_return_none_or_k val _ _ _ h with hleft | ⟨_, _, _, hkt⟩
      · exact hno (HasReturnInHead.unary_arg hleft)
      · exact absurd hkt (ANF.bindComplex_never_return_none_general _ _ _ _)
    | getEnv envPtr _ =>
      exfalso; simp only [ANF.normalizeExpr] at h
      rcases ANF.normalizeExpr_return_none_or_k envPtr _ _ _ h with hleft | ⟨_, _, _, hkt⟩
      · exact hno (HasReturnInHead.getEnv_env hleft)
      · exact absurd hkt (ANF.bindComplex_never_return_none_general _ _ _ _)
    | makeClosure _ env =>
      exfalso; simp only [ANF.normalizeExpr] at h
      rcases ANF.normalizeExpr_return_none_or_k env _ _ _ h with hleft | ⟨_, _, _, hkt⟩
      · exact hno (HasReturnInHead.makeClosure_env hleft)
      · exact absurd hkt (ANF.bindComplex_never_return_none_general _ _ _ _)
    | setProp obj _ val =>
      exfalso; simp only [ANF.normalizeExpr] at h
      rcases ANF.normalizeExpr_return_none_or_k obj _ _ _ h with hleft | ⟨_, _, _, hkt⟩
      · exact hno (HasReturnInHead.setProp_obj hleft)
      · rcases ANF.normalizeExpr_return_none_or_k val _ _ _ hkt with hleft | ⟨_, _, _, hkt₂⟩
        · exact hno (HasReturnInHead.setProp_val hleft)
        · exact absurd hkt₂ (ANF.bindComplex_never_return_none_general _ _ _ _)
    | binary _ lhs rhs =>
      exfalso; simp only [ANF.normalizeExpr] at h
      rcases ANF.normalizeExpr_return_none_or_k lhs _ _ _ h with hleft | ⟨_, _, _, hkt⟩
      · exact hno (HasReturnInHead.binary_lhs hleft)
      · rcases ANF.normalizeExpr_return_none_or_k rhs _ _ _ hkt with hleft | ⟨_, _, _, hkt₂⟩
        · exact hno (HasReturnInHead.binary_rhs hleft)
        · exact absurd hkt₂ (ANF.bindComplex_never_return_none_general _ _ _ _)
    | getIndex obj idx =>
      exfalso; simp only [ANF.normalizeExpr] at h
      rcases ANF.normalizeExpr_return_none_or_k obj _ _ _ h with hleft | ⟨_, _, _, hkt⟩
      · exact hno (HasReturnInHead.getIndex_obj hleft)
      · rcases ANF.normalizeExpr_return_none_or_k idx _ _ _ hkt with hleft | ⟨_, _, _, hkt₂⟩
        · exact hno (HasReturnInHead.getIndex_idx hleft)
        · exact absurd hkt₂ (ANF.bindComplex_never_return_none_general _ _ _ _)
    | setIndex obj idx val =>
      exfalso; simp only [ANF.normalizeExpr] at h
      rcases ANF.normalizeExpr_return_none_or_k obj _ _ _ h with hleft | ⟨_, _, _, hkt⟩
      · exact hno (HasReturnInHead.setIndex_obj hleft)
      · rcases ANF.normalizeExpr_return_none_or_k idx _ _ _ hkt with hleft | ⟨_, _, _, hkt₂⟩
        · exact hno (HasReturnInHead.setIndex_idx hleft)
        · rcases ANF.normalizeExpr_return_none_or_k val _ _ _ hkt₂ with hleft | ⟨_, _, _, hkt₃⟩
          · exact hno (HasReturnInHead.setIndex_val hleft)
          · exact absurd hkt₃ (ANF.bindComplex_never_return_none_general _ _ _ _)
    | call f env args =>
      exfalso; simp only [ANF.normalizeExpr] at h
      rcases ANF.normalizeExpr_return_none_or_k f _ _ _ h with hleft | ⟨_, _, _, hkt⟩
      · exact hno (HasReturnInHead.call_func hleft)
      · rcases ANF.normalizeExpr_return_none_or_k env _ _ _ hkt with hleft | ⟨_, _, _, hkt₂⟩
        · exact hno (HasReturnInHead.call_env hleft)
        · have args_ih : ∀ e, e ∈ args → ∀ k' n m,
              (ANF.normalizeExpr e k').run n = .ok (ANF.Expr.return none, m) →
              HasReturnInHead e ∨ ∃ t n' m', (k' t).run n' = .ok (ANF.Expr.return none, m') :=
            fun e he => ANF.normalizeExpr_return_none_or_k e
          rcases normalizeExprList_return_none_or_k args args_ih _ _ _ hkt₂ with hleft | ⟨_, _, _, hkt₃⟩
          · exact hno (HasReturnInHead.call_args hleft)
          · exact absurd hkt₃ (ANF.bindComplex_never_return_none_general _ _ _ _)
    | newObj f env args =>
      exfalso; simp only [ANF.normalizeExpr] at h
      rcases ANF.normalizeExpr_return_none_or_k f _ _ _ h with hleft | ⟨_, _, _, hkt⟩
      · exact hno (HasReturnInHead.newObj_func hleft)
      · rcases ANF.normalizeExpr_return_none_or_k env _ _ _ hkt with hleft | ⟨_, _, _, hkt₂⟩
        · exact hno (HasReturnInHead.newObj_env hleft)
        · have args_ih : ∀ e, e ∈ args → ∀ k' n m,
              (ANF.normalizeExpr e k').run n = .ok (ANF.Expr.return none, m) →
              HasReturnInHead e ∨ ∃ t n' m', (k' t).run n' = .ok (ANF.Expr.return none, m') :=
            fun e he => ANF.normalizeExpr_return_none_or_k e
          rcases normalizeExprList_return_none_or_k args args_ih _ _ _ hkt₂ with hleft | ⟨_, _, _, hkt₃⟩
          · exact hno (HasReturnInHead.newObj_args hleft)
          · exact absurd hkt₃ (ANF.bindComplex_never_return_none_general _ _ _ _)
    | makeEnv values =>
      exfalso; simp only [ANF.normalizeExpr] at h
      have vals_ih : ∀ e, e ∈ values → ∀ k' n m,
          (ANF.normalizeExpr e k').run n = .ok (ANF.Expr.return none, m) →
          HasReturnInHead e ∨ ∃ t n' m', (k' t).run n' = .ok (ANF.Expr.return none, m') :=
        fun e he => ANF.normalizeExpr_return_none_or_k e
      rcases normalizeExprList_return_none_or_k values vals_ih _ _ _ h with hleft | ⟨_, _, _, hkt⟩
      · exact hno (HasReturnInHead.makeEnv_values hleft)
      · exact absurd hkt (ANF.bindComplex_never_return_none_general _ _ _ _)
    | objectLit props =>
      exfalso; simp only [ANF.normalizeExpr] at h
      have props_ih : ∀ (name : Flat.PropName) (e : Flat.Expr), (name, e) ∈ props →
          ∀ k' n m,
          (ANF.normalizeExpr e k').run n = .ok (ANF.Expr.return none, m) →
          HasReturnInHead e ∨ ∃ t n' m', (k' t).run n' = .ok (ANF.Expr.return none, m') :=
        fun name e he => ANF.normalizeExpr_return_none_or_k e
      rcases normalizeProps_return_none_or_k props props_ih _ _ _ h with hleft | ⟨_, _, _, hkt⟩
      · exact hno (HasReturnInHead.objectLit_props hleft)
      · exact absurd hkt (ANF.bindComplex_never_return_none_general _ _ _ _)
