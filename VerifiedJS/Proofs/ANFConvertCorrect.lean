          · split at hstep
            · simp [Flat.pushTrace] at hstep
              obtain ⟨_, rfl⟩ := hstep
              exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.setProp_val h)) (by assumption)
            · simp at hstep
          · simp at hstep
      · split at hstep
        · simp at hstep
        · split at hstep
          · split at hstep
            · simp [Flat.pushTrace] at hstep
              obtain ⟨_, rfl⟩ := hstep
              exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.setProp_val h)) (by assumption)
            · simp at hstep
          · simp at hstep
    | getIndex obj idx =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep
            obtain ⟨_, rfl⟩ := hstep
            exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.getIndex_obj h)) (by assumption)
          · simp at hstep
        · simp at hstep
      · split at hstep
        · simp at hstep
        · split at hstep
          · split at hstep
            · simp [Flat.pushTrace] at hstep
              obtain ⟨_, rfl⟩ := hstep
              exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.getIndex_idx h)) (by assumption)
            · simp at hstep
          · simp at hstep
      · split at hstep
        · simp at hstep
        · split at hstep
          · split at hstep
            · simp [Flat.pushTrace] at hstep
              obtain ⟨_, rfl⟩ := hstep
              exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.getIndex_idx h)) (by assumption)
            · simp at hstep
          · simp at hstep
      · split at hstep
        · simp at hstep
        · split at hstep
          · split at hstep
            · simp [Flat.pushTrace] at hstep
              obtain ⟨_, rfl⟩ := hstep
              exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.getIndex_idx h)) (by assumption)
            · simp at hstep
          · simp at hstep
    | setIndex obj idx val =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      have hncf_obj : ¬HasNonCallFrameTryCatchInHead obj := fun h => hncf_e (.setIndex_obj h)
      have hncf_idx : ¬HasNonCallFrameTryCatchInHead idx := fun h => hncf_e (.setIndex_idx h)
      have hncf_val : ¬HasNonCallFrameTryCatchInHead val := fun h => hncf_e (.setIndex_val h)
      split at hstep <;>
        (try split at hstep) <;> (try split at hstep) <;>
        (try split at hstep) <;> (try split at hstep) <;>
        first
        | simp at hstep
        | (simp [Flat.pushTrace] at hstep
           obtain ⟨_, rfl⟩ := hstep
           exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (by assumption) (by assumption))
    | getEnv envE idx =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · simp at hstep
      · simp at hstep
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep
            obtain ⟨_, rfl⟩ := hstep
            exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.getEnv_env h)) (by assumption)
          · simp at hstep
        · simp at hstep
    | makeClosure funcIdx envE =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · simp at hstep
      · simp [Flat.pushTrace] at hstep; obtain ⟨_, rfl⟩ := hstep; exact ⟨_, rfl⟩
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep
            obtain ⟨_, rfl⟩ := hstep
            exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.makeClosure_env h)) (by assumption)
          · simp at hstep
        · simp at hstep
    | call f envE args =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep
            obtain ⟨_, rfl⟩ := hstep
            exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.call_func h)) (by assumption)
          · simp at hstep
        · simp at hstep
      · split at hstep
        · split at hstep
          · split at hstep
            · simp [Flat.pushTrace] at hstep
              obtain ⟨_, rfl⟩ := hstep
              exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.call_env h)) (by assumption)
            · simp at hstep
          · simp at hstep
        · split at hstep
          · -- all args values: call. All branches produce .silent/.log, contradicts .error
            simp at hstep
          · split at hstep
            · rename_i hfnv
              split at hstep
              · split at hstep
                · simp [Flat.pushTrace] at hstep
                  obtain ⟨_, rfl⟩ := hstep
                  exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; have := Flat.firstNonValueExpr_depth hfnv; omega) (fun h => hncf_e (.call_args (HasNonCallFrameTryCatchInHeadList_of_firstNonValue hfnv h))) (by assumption)
                · simp at hstep
              · simp at hstep
            · simp at hstep
    | newObj f envE args =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep
            obtain ⟨_, rfl⟩ := hstep
            exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.newObj_func h)) (by assumption)
          · simp at hstep
        · simp at hstep
      · split at hstep
        · split at hstep
          · split at hstep
            · simp [Flat.pushTrace] at hstep
              obtain ⟨_, rfl⟩ := hstep
              exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega) (fun h => hncf_e (.newObj_env h)) (by assumption)
            · simp at hstep
          · simp at hstep
        · split at hstep
          · simp at hstep
          · split at hstep
            · rename_i hfnv
              split at hstep
              · split at hstep
                · simp [Flat.pushTrace] at hstep
                  obtain ⟨_, rfl⟩ := hstep
                  exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; have := Flat.firstNonValueExpr_depth hfnv; omega) (fun h => hncf_e (.newObj_args (HasNonCallFrameTryCatchInHeadList_of_firstNonValue hfnv h))) (by assumption)
                · simp at hstep
              · simp at hstep
            · simp at hstep
    | makeEnv values =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · simp at hstep
      · split at hstep
        · rename_i hfnv
          split at hstep
          · split at hstep
            · simp [Flat.pushTrace] at hstep
              obtain ⟨_, rfl⟩ := hstep
              exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; have := Flat.firstNonValueExpr_depth hfnv; omega) (fun h => hncf_e (.makeEnv_values (HasNonCallFrameTryCatchInHeadList_of_firstNonValue hfnv h))) (by assumption)
            · simp at hstep
          · simp at hstep
        · simp at hstep
    | arrayLit elems =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · simp at hstep
      · split at hstep
        · rename_i hfnv
          split at hstep
          · split at hstep
            · simp [Flat.pushTrace] at hstep
              obtain ⟨_, rfl⟩ := hstep
              exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; have := Flat.firstNonValueExpr_depth hfnv; omega) (fun h => hncf_e (.arrayLit_elems (HasNonCallFrameTryCatchInHeadList_of_firstNonValue hfnv h))) (by assumption)
            · simp at hstep
          · simp at hstep
        · simp at hstep
    | objectLit props =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · simp at hstep
      · split at hstep
        · rename_i hfnv
          split at hstep
          · split at hstep
            · simp [Flat.pushTrace] at hstep
              obtain ⟨_, rfl⟩ := hstep
              exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; have := Flat.firstNonValueProp_depth hfnv; omega) (fun h => hncf_e (.objectLit_props (HasNonCallFrameTryCatchInHeadProps_of_firstNonValue hfnv h))) (by assumption)
            · simp at hstep
          · simp at hstep
        · simp at hstep
    | tryCatch body catchParam catchBody fin =>
      -- ¬HasNonCallFrameTryCatchInHead → catchParam = "__call_frame_return__"
      by_cases hcp : catchParam = "__call_frame_return__"
      · -- Call-frame: use callFrame_tryCatch_step_error_isLit
        rw [hcp] at hstep
        exact ⟨.undefined, callFrame_tryCatch_step_error_isLit hstep⟩
      · -- Non-call-frame: impossible
        exfalso; exact hncf_e (.tryCatch_direct hcp)

/-- Non-error steps preserve ¬HasNonCallFrameTryCatchInHead.
    Key insight: the only step that introduces .tryCatch is function call execution
    (.call f env args with all values), which produces a call-frame tryCatch
    (catchParam = "__call_frame_return__"). Non-call-frame tryCatch only comes from
    source-level try/catch, which is already in the expression. -/
private theorem step_nonError_preserves_noNonCallFrameTryCatch
    {e : Flat.Expr} {env : Flat.Env} {heap : Core.Heap} {trace : List Core.TraceEvent}
    {funcs : Array Flat.FuncDef} {cs : List Flat.Env}
    {sf' : Flat.State} {t : Core.TraceEvent}
    (hncf : ¬HasNonCallFrameTryCatchInHead e)
    (hstep : Flat.step? ⟨e, env, heap, trace, funcs, cs⟩ = some (t, sf'))
    (hnoerr : ∀ msg, t ≠ .error msg) :
    ¬HasNonCallFrameTryCatchInHead sf'.expr := by
  -- Strong induction on expression depth, case split on expression.
  suffices hmain : ∀ (n : Nat) (e : Flat.Expr) (env : Flat.Env) (heap : Core.Heap)
      (trace : List Core.TraceEvent) (funcs : Array Flat.FuncDef) (cs : List Flat.Env)
      (sf' : Flat.State) (t : Core.TraceEvent),
      e.depth ≤ n →
      ¬HasNonCallFrameTryCatchInHead e →
      Flat.step? ⟨e, env, heap, trace, funcs, cs⟩ = some (t, sf') →
      (∀ msg, t ≠ .error msg) →
      ¬HasNonCallFrameTryCatchInHead sf'.expr by
    exact hmain e.depth e env heap trace funcs cs sf' t (Nat.le_refl _) hncf hstep hnoerr
  intro n
  induction n with
  | zero =>
    intro e env heap trace funcs cs sf' t hd hncf hstep hnoerr
    cases e with
    | lit => simp [Flat.step?] at hstep
    | var name =>
      unfold Flat.step? at hstep; dsimp only [] at hstep; split at hstep
      · obtain ⟨_, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]; intro h; exact nomatch h
      · obtain ⟨rfl, _⟩ := hstep; exact absurd rfl (hnoerr _)
    | this =>
      unfold Flat.step? at hstep; dsimp only [] at hstep; split at hstep
      · obtain ⟨_, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]; intro h; exact nomatch h
      · obtain ⟨_, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]; intro h; exact nomatch h
    | «break» =>
      unfold Flat.step? at hstep; simp [Flat.pushTrace] at hstep; exact absurd hstep.1.symm (hnoerr _)
    | «continue» =>
      unfold Flat.step? at hstep; simp [Flat.pushTrace] at hstep; exact absurd hstep.1.symm (hnoerr _)
    | «return» arg =>
      cases arg with
      | none => unfold Flat.step? at hstep; simp [Flat.pushTrace] at hstep; exact absurd hstep.1.symm (hnoerr _)
      | some => simp [Flat.Expr.depth] at hd; omega
    | yield arg d =>
      cases arg with
      | none =>
        unfold Flat.step? at hstep; dsimp only [] at hstep
        obtain ⟨_, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]; intro h; exact nomatch h
      | some => simp [Flat.Expr.depth] at hd; omega
    | seq _ _ | «let» _ _ _ | assign _ _ | «if» _ _ _
    | binary _ _ _ | unary _ _ | typeof _ | call _ _ _
    | newObj _ _ _ | getProp _ _ | setProp _ _ _ | getIndex _ _
    | setIndex _ _ _ | deleteProp _ _ | throw _ | tryCatch _ _ _ _
    | while_ _ _ | labeled _ _ | await _ | getEnv _ _
    | makeClosure _ _ | makeEnv _ | objectLit _ | arrayLit _ =>
      simp [Flat.Expr.depth, Flat.Expr.listDepth, Flat.Expr.propListDepth] at hd; omega
  | succ n ih =>
    intro e env heap trace funcs cs sf' t hd hncf hstep hnoerr
    cases e with
    | lit => simp [Flat.step?] at hstep
    | var name =>
      unfold Flat.step? at hstep; dsimp only [] at hstep; split at hstep
      · obtain ⟨_, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]; intro h; exact nomatch h
      · obtain ⟨rfl, _⟩ := hstep; exact absurd rfl (hnoerr _)
    | this =>
      unfold Flat.step? at hstep; dsimp only [] at hstep; split at hstep
      · obtain ⟨_, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]; intro h; exact nomatch h
      · obtain ⟨_, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]; intro h; exact nomatch h
    | «break» =>
      unfold Flat.step? at hstep; simp [Flat.pushTrace] at hstep; exact absurd hstep.1.symm (hnoerr _)
    | «continue» =>
      unfold Flat.step? at hstep; simp [Flat.pushTrace] at hstep; exact absurd hstep.1.symm (hnoerr _)
    | «return» arg =>
      cases arg with
      | none => unfold Flat.step? at hstep; simp [Flat.pushTrace] at hstep; exact absurd hstep.1.symm (hnoerr _)
      | some v =>
        unfold Flat.step? at hstep; dsimp only [] at hstep
        split at hstep
        · -- value: error step, contradicts hnoerr
          simp [Flat.pushTrace] at hstep; exact absurd hstep.1.symm (hnoerr _)
        · split at hstep
          · split at hstep
            · -- error sub-step: contradicts hnoerr
              simp [Flat.pushTrace] at hstep; obtain ⟨rfl, _⟩ := hstep; exact absurd rfl (hnoerr _)
            · -- non-error sub-step: .return (some se.expr)
              obtain ⟨rfl, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]
              intro h; cases h with
              | return_some_arg h' =>
                exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega)
                  (fun h => hncf (.return_some_arg h)) ‹_› hnoerr h'
          · simp at hstep
    | yield arg d =>
      cases arg with
      | none =>
        unfold Flat.step? at hstep; dsimp only [] at hstep
        obtain ⟨_, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]; intro h; exact nomatch h
      | some v =>
        unfold Flat.step? at hstep; dsimp only [] at hstep
        split at hstep
        · obtain ⟨_, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]; intro h; exact nomatch h
        · split at hstep
          · split at hstep
            · simp [Flat.pushTrace] at hstep; obtain ⟨rfl, _⟩ := hstep; exact absurd rfl (hnoerr _)
            · obtain ⟨rfl, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]
              intro h; cases h with
              | yield_some_arg h' =>
                exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega)
                  (fun h => hncf (.yield_some_arg h)) ‹_› hnoerr h'
          · simp at hstep
    | seq a b =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · -- value a: step to b
        obtain ⟨_, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]
        intro h; exact hncf (.seq_right h)
      · split at hstep
        · split at hstep
          · -- error sub-step on a: contradicts hnoerr
            simp [Flat.pushTrace] at hstep; obtain ⟨rfl, _⟩ := hstep; exact absurd rfl (hnoerr _)
          · -- non-error sub-step on a: .seq sa.expr b
            obtain ⟨rfl, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]
            intro h; cases h with
            | seq_left h' =>
              exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega)
                (fun h => hncf (.seq_left h)) ‹_› hnoerr h'
            | seq_right h' => exact hncf (.seq_right h')
        · simp at hstep
    | «let» name init body =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · -- value init: step to body
        obtain ⟨_, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]
        intro h; exact hncf (.let_body h)
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep; obtain ⟨rfl, _⟩ := hstep; exact absurd rfl (hnoerr _)
          · obtain ⟨rfl, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]
            intro h; cases h with
            | let_init h' =>
              exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega)
                (fun h => hncf (.let_init h)) ‹_› hnoerr h'
            | let_body h' => exact hncf (.let_body h')
        · simp at hstep
    | assign name rhs =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · obtain ⟨_, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]; intro h; exact nomatch h
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep; obtain ⟨rfl, _⟩ := hstep; exact absurd rfl (hnoerr _)
          · obtain ⟨rfl, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]
            intro h; cases h with
            | assign_val h' =>
              exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega)
                (fun h => hncf (.assign_val h)) ‹_› hnoerr h'
        · simp at hstep
    | «if» cond then_ else_ =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · -- value cond: step to then_ or else_
        obtain ⟨_, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]
        split
        · intro h; exact hncf (.if_then h)
        · intro h; exact hncf (.if_else h)
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep; obtain ⟨rfl, _⟩ := hstep; exact absurd rfl (hnoerr _)
          · obtain ⟨rfl, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]
            intro h; cases h with
            | if_cond h' =>
              exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega)
                (fun h => hncf (.if_cond h)) ‹_› hnoerr h'
            | if_then h' => exact hncf (.if_then h')
            | if_else h' => exact hncf (.if_else h')
        · simp at hstep
    | while_ cond body =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      obtain ⟨_, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]
      intro h; cases h with
      | if_cond h' => exact hncf (.while_cond h')
      | if_then h' =>
        cases h' with
        | seq_left h'' => exact hncf (.while_body h'')
        | seq_right h'' => exact hncf h''
      | if_else h' => exact nomatch h'
    | labeled _ body =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      obtain ⟨_, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]
      intro h; exact hncf (.labeled_body h)
    | unary op arg =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · obtain ⟨_, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]; intro h; exact nomatch h
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep; obtain ⟨rfl, _⟩ := hstep; exact absurd rfl (hnoerr _)
          · obtain ⟨rfl, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]
            intro h; cases h with
            | unary_arg h' =>
              exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega)
                (fun h => hncf (.unary_arg h)) ‹_› hnoerr h'
        · simp at hstep
    | typeof arg =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · obtain ⟨_, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]; intro h; exact nomatch h
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep; obtain ⟨rfl, _⟩ := hstep; exact absurd rfl (hnoerr _)
          · obtain ⟨rfl, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]
            intro h; cases h with
            | typeof_arg h' =>
              exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega)
                (fun h => hncf (.typeof_arg h)) ‹_› hnoerr h'
        · simp at hstep
    | throw arg =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · -- value: error step, contradicts hnoerr
        simp [Flat.pushTrace] at hstep; exact absurd hstep.1.symm (hnoerr _)
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep; obtain ⟨rfl, _⟩ := hstep; exact absurd rfl (hnoerr _)
          · obtain ⟨rfl, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]
            intro h; cases h with
            | throw_arg h' =>
              exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega)
                (fun h => hncf (.throw_arg h)) ‹_› hnoerr h'
        · simp at hstep
    | await arg =>
      unfold Flat.step? at hstep; dsimp only [] at hstep
      split at hstep
      · obtain ⟨_, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]; intro h; exact nomatch h
      · split at hstep
        · split at hstep
          · simp [Flat.pushTrace] at hstep; obtain ⟨rfl, _⟩ := hstep; exact absurd rfl (hnoerr _)
          · obtain ⟨rfl, rfl⟩ := hstep; simp only [Flat.pushTrace, Flat.State.expr]
            intro h; cases h with
            | await_arg h' =>
              exact ih _ _ _ _ _ _ _ _ (by simp [Flat.Expr.depth] at hd ⊢; omega)
