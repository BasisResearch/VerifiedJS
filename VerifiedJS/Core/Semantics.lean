    · simp at hstuck
    · split at hstuck
      · simp at hstuck
      · rename_i _ hsub; have ⟨v, hv⟩ := stuck_implies_lit_aux _ _ _ _ _ _ hsub; subst hv; simp_all [exprValue?]
  | await arg =>
