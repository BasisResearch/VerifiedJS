    (h1 : Behaves p b) (_h2 : Behaves p b) :
    ∃ sf, Steps (initialState p) b sf ∧ step? sf = none := by
  obtain ⟨sf, hsteps, hhalt⟩ := h1
  exact ⟨sf, hsteps, hhalt⟩

