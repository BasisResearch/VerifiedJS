        · simp at hstuck
        · rename_i hsub; have ⟨v, hv⟩ := stuck_implies_lit_aux _ _ _ _ _ _ hsub; subst hv; simp_all [exprValue?]
      · split at hstuck <;> simp at hstuck
  | getIndex obj idx =>
