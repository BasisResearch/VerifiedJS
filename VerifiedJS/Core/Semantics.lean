    (_h : step? s = some (t, s')) :
    ∃ e' env' heap' trace' funcs' cs',
      s' = ⟨e', env', heap', trace', funcs', cs'⟩ :=
  ⟨s'.expr, s'.env, s'.heap, s'.trace, s'.funcs, s'.callStack, rfl⟩

