            exfalso; exact firstNonValueExpr_not_lit (by assumption) _ rfl
        · exfalso; exact allValues_firstNonValue_contra (by assumption) (by assumption)
  | objectLit props =>
    unfold step? at hstuck; simp only [] at hstuck
    split at hstuck
    · split at hstuck
