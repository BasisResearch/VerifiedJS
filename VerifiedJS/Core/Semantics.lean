    (trace : List TraceEvent) (funcs : Array FuncClosure)
    (cs : List (List (VarName × Value))) (t : TraceEvent) :
    pushTrace ⟨e, env, heap, trace, funcs, cs⟩ t =
      ⟨e, env, heap, trace ++ [t], funcs, cs⟩ := by
  simp [pushTrace]

