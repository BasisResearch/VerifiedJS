  simp [abstractEq]

/-- §7.2.14 abstractEq: bool/bool delegates to BEq. -/
theorem abstractEq_bool (a b : Bool) : abstractEq (.bool a) (.bool b) = (a == b) := by
  simp [abstractEq]

