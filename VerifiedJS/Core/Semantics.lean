/-- `Array.set!` preserves array size. -/
private theorem Array.size_set!_le {α : Type} (a : Array α) (i : Nat) (v : α) :
    a.size ≤ (a.set! i v).size := by
  simp [Array.set!, Array.setIfInBounds]
  split <;> simp

